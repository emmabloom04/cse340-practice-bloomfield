<%- include('../partials/header') %>
<main>
    <div class="course-header">
        <h1><%= faculty.name %></h1>
        <p class="course-meta"><%= faculty.title %> • <%= faculty.department %></p>
    </div>

    <div class="sections">
        <div class="sections-header">
            <h2>Contact Information</h2>
        </div>

        <div class="section-list">
            <div class="section-card">
                <div class="section-time">Office: <%= faculty.office %></div>
                <div class="section-room">Phone: <%= faculty.phone %></div>
                <div class="section-professor">Email: <%= faculty.email %></div>
            </div>
        </div>
    </div>

    <div class="navigation">
        <p><a href="/faculty">&larr; Back to Faculty List</a></p>
    </div>
</main>

<%- include('../partials/footer') %>
